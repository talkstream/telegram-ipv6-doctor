#!/bin/bash
# fake nc: the tool always invokes it as `nc [flags] <host> <port>`, so the host is the
# second-to-last argument. No eval — shellcheck must be able to see the assignment.
host=""
prev=""
for a in "$@"; do
  prev="$host"
  host="$a"
done
host="$prev"   # second-to-last argument
case "$host" in
  *:*)
    case "$host" in
      2001:b28:*|2001:67c:4e8:*) [ "${FAKE_V6_DC:-fail}" = "ok" ] && exit 0 || exit 1 ;;
      *)                         [ "${FAKE_V6_CONTROL:-ok}" = "ok" ] && exit 0 || exit 1 ;;
    esac ;;
  *) [ "${FAKE_V4_OK:-1}" = "1" ] && exit 0 || exit 1 ;;
esac
