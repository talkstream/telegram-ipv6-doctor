#!/bin/bash
if [ "${1:-}" = "-rnf" ] && [ "${2:-}" = "inet" ]; then
  [ "${FAKE_VPN:-0}" = "1" ] && echo "default   utun4   UGScg   utun4" || echo "default   192.168.1.1   UGScg   en0"
  exit 0
fi
# inet6 table: NAT64 route and our own reject routes (none by default)
[ "${FAKE_NAT64:-0}" = "1" ] && echo "64:ff9b::/96   link#1   UCS   en0"
exit 0
